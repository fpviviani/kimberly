# Copy this file to .env and fill in the values
#
#   cp .env.example .env

# Letterboxd
# PT: URL da lista do Letterboxd (usado quando você roda o cli.js sem argumento). (Obrigatório)
# EN: Letterboxd list URL (used when running cli.js without args). (Required)
LETTERBOXD_LIST_URL=

# Prowlarr
# PT: URL do Prowlarr (ex.: http://localhost:9696). (Opcional; default: http://localhost:9696)
# EN: Prowlarr base URL (e.g. http://localhost:9696). (Optional; default: http://localhost:9696)
PROWLARR_URL=http://localhost:9696

# PT: API key do Prowlarr (Settings → General). (Obrigatório)
# EN: Prowlarr API key (Settings → General). (Required)
PROWLARR_API_KEY=

# PT: Quantas buscas no Prowlarr em paralelo. (Opcional; default: 3)
# EN: How many Prowlarr searches in parallel. (Optional; default: 3)
CONCURRENCY=3

# PT: Timeout (ms) das requisições ao Prowlarr. (Opcional; default: 300000)
# EN: Prowlarr request timeout (ms). (Optional; default: 300000)
PROWLARR_TIMEOUT_MS=300000

# Filtering / selection
# PT: Tamanho mínimo (GiB) do release (filtra coisas muito pequenas). (Opcional; default: 1)
# EN: Minimum release size (GiB). (Optional; default: 1)
MIN_GIB=1

# PT: Tamanho máximo (GiB) do release. (Opcional; default: 10)
# EN: Maximum release size (GiB). (Optional; default: 10)
MAX_GIB=10

# PT: Máximo de releases mantidos por filme no cache. (Opcional; default: 20)
# EN: Max releases kept per movie in the cache. (Optional; default: 20)
MAX_TORRENTS=20

# PT: Se true, prioriza só 1080p/2160p quando existir pelo menos um HD. (Opcional; default: true)
# EN: If true, keep only 1080p/2160p releases when any exist. (Optional; default: true)
HD_ONLY=true

# PT: Se true, exige que o título do release bata com o título do Letterboxd (tokens). (Opcional; default: true)
# EN: If true, require release title to match the Letterboxd title (token-based). (Optional; default: true)
ENGLISH_TITLE_ONLY=true

# PT: Termos para excluir do título do release (separados por vírgula). (Opcional)
# EN: Comma-separated terms to exclude from release titles. (Optional)
EXCLUDE_TERMS=

# PT: Bucket (GiB) para deduplicação por tamanho (agrupar releases muito parecidos e manter só 1). (Opcional; default: 0.1)
# EN: Size bucket (GiB) for de-duplication (group similar releases and keep only one). (Optional; default: 0.1)
DEDUPE_SIZE_BUCKET_GIB=0.1

# Cache / orchestration
# PT: Arquivo JSON do cache. (Opcional; default: cache.json)
# EN: Cache JSON file. (Optional; default: cache.json)
CACHE_FILE=cache.json

# PT: Se true, reescreve o cache do filme mesmo se já existir. (Opcional; default: false)
# EN: If true, rewrite a movie cache entry even if it already exists. (Optional; default: false)
REWRITE_CACHE=false

# PT: Limite de filmes novos adicionados ao cache por execução. (Opcional; default: 5)
# EN: Limit how many new movies can be added per run. (Optional; default: 5)
MAX_NEW_MOVIES_PER_RUN=5

# PT: Se true, o cli.js roda o debrid-cli.js automaticamente após finalizar (manda torrents pro Real-Debrid e tenta finalizar download/import). (Opcional; default: false)
# EN: If true, cli.js runs debrid-cli.js after finishing (send torrents to Real-Debrid and try to finalize download/import). (Optional; default: false)
EXECUTE_DEBRID=false

# Real-Debrid
# PT: Base URL da API do Real-Debrid (default já funciona). (Opcional; default: https://api.real-debrid.com/rest/1.0)
# EN: Real-Debrid API base URL (default should work). (Optional; default: https://api.real-debrid.com/rest/1.0)
REALDEBRID_URL=https://api.real-debrid.com/rest/1.0

# PT: Token/API key do Real-Debrid. (Opcional)
# EN: Real-Debrid token/API key. (Optional)
REALDEBRID_API_KEY=

# PT: Logs detalhados do fluxo de debrid. (Opcional; default: false)
# EN: Verbose logging for the debrid flow. (Optional; default: false)
DEBRID_VERBOSE=false

# PT: Delay base (ms) para retry quando tomar 429 (rate limit). (Opcional; default: 3000)
# EN: Base retry delay (ms) on HTTP 429 rate limit. (Optional; default: 3000)
DEBRID_RETRY_DELAY_MS=3000

# Auto-download
# PT: Se true, baixa automaticamente quando o torrent termina de ser cacheado no Real-Debrid. (Opcional; default: false)
# EN: If true, auto-download when the torrent finishes caching on Real-Debrid. (Optional; default: false)
AUTO_DOWNLOAD=false

# PT: Pasta final da sua biblioteca de filmes (destino). Se integrar com Plex, use a mesma pasta da biblioteca de Filmes do Plex. (Opcional)
# EN: Final movies library folder (destination). If integrating with Plex, use the same Movies library folder Plex is watching. (Optional)
AUTO_DOWNLOAD_DEST_DIR=

# PT: Pasta temporária de staging (fora da biblioteca do Plex). (default: staging downloads) (Opcional; default: staging downloads)
# EN: Temporary staging folder (keep outside Plex library). (default: staging downloads) (Optional; default: staging downloads)
AUTO_DOWNLOAD_STAGING_DIR=staging downloads

# PT: Se true, reaproveita staging se uma execução anterior foi interrompida. (Opcional; default: true)
# EN: If true, reuse staging if a previous run was interrupted. (Optional; default: true)
AUTO_DOWNLOAD_REUSE_STAGING=true

# PT: Se true, a pasta do filme fica só com o nome (sem ano/tmdb). (Opcional; default: true)
# EN: If true, movie folder name is only the title (no year/tmdb). (Optional; default: true)
DIR_NAME_MOVIE_ONLY=true

# PT: Caminho do 7z (principalmente no Windows) para extrair .rar. (Opcional)
# EN: Path to 7z binary (mainly on Windows) to extract .rar. (Optional)
SEVEN_ZIP_PATH=

# Plex
# PT: Base URL do Plex (ex.: http://127.0.0.1:32400). (Opcional; default: http://127.0.0.1:32400)
# EN: Plex base URL (e.g. http://127.0.0.1:32400). (Optional; default: http://127.0.0.1:32400)
PLEX_BASE_URL=http://127.0.0.1:32400

# PT: Token do Plex. (Opcional)
# EN: Plex token. (Optional)
PLEX_TOKEN=

# PT: ID da biblioteca/section de Filmes no Plex (se você só tiver uma biblioteca, provavelmente será 1). (Opcional; default: 1)
# EN: Plex Movies library section id (if you only have one library, it is likely 1). (Optional; default: 1)
PLEX_SECTION_ID_FILMES=1

# PT: Se true, dá refresh no Plex após o auto-download finalizar. (Opcional; default: false)
# EN: If true, refresh Plex after auto-download. (Optional; default: false)
PLEX_REFRESH_AFTER_DOWNLOAD=false

# Radarr
# PT: Base URL do Radarr (ex.: http://127.0.0.1:7878). Necessário se você quer que o Bazarr baixe legendas via Radarr. (Opcional; default: http://127.0.0.1:7878)
# EN: Radarr base URL (e.g. http://127.0.0.1:7878). Useful if you want Bazarr to fetch subtitles via Radarr. (Optional; default: http://127.0.0.1:7878)
RADARR_BASE_URL=http://127.0.0.1:7878

# PT: API key do Radarr. (Opcional)
# EN: Radarr API key. (Optional)
RADARR_API_KEY=

# PT: Pasta raiz de filmes no Radarr. Se integrar com Plex, use a mesma pasta da biblioteca de Filmes do Plex. (Opcional; default: /path/to/Movies)
# EN: Radarr root folder path. If integrating with Plex, use the same Movies library folder Plex is watching. (Optional; default: /path/to/Movies)
RADARR_ROOT_FOLDER_PATH=/path/to/Movies

# PT: ID do quality profile no Radarr (se você não sabe o que está fazendo, mantenha o default). (Opcional; default: 7)
# EN: Radarr quality profile id (keep the default if you are not sure). (Optional; default: 7)
RADARR_QUALITY_PROFILE_ID=7

# PT: Se true, importa o filme no Radarr após baixar. Para o Bazarr baixar legendas automaticamente via Radarr, isso precisa estar true. (Opcional; default: false)
# EN: If true, import the movie into Radarr after download. If you want Bazarr to fetch subtitles via Radarr, this should be true. (Optional; default: false)
RADARR_IMPORT_AFTER_DOWNLOAD=false

# Logging
# PT: Se true, grava logs diários em ./logs. (Opcional; default: true)
# EN: If true, append daily logs under ./logs. (Optional; default: true)
LOGS_ENABLED=true

# PT: Quantos dias manter de logs (contando hoje). (Opcional; default: 2)
# EN: How many log days to keep (counting today). (Optional; default: 2)
LOGS_RETENTION_DAYS=2

# Scheduling (cron/tasks)
# PT: Intervalo (min) para rodar o cli.js via cron/task scheduler. (Opcional; default: 20)
# EN: Interval (min) to run cli.js via cron/task scheduler. (Optional; default: 20)
CRON_CLI_EVERY_MIN=20

# PT: Quantos minutos após o cli.js rodar para rodar o debrid-monitor.js. (Opcional; default: 10)
# EN: How many minutes after cli.js to run debrid-monitor.js. (Optional; default: 10)
CRON_MONITOR_AFTER_CLI_MIN=10

# Output
# PT: Se true/false, imprime um JSON mais detalhado ao final (quando suportado). (Opcional; default: false)
# EN: If true/false, print a more detailed JSON at the end (when supported). (Optional; default: false)
OUTPUT_JSON=false
