# Copy this file to .env and fill in the values
#
#   cp .env.example .env

# Prowlarr
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=

# Real-Debrid
REALDEBRID_URL=""
REALDEBRID_API_KEY=

# Mock provider base URL (used by the mock provider / test server)
MOCK_DEBRID_BASE_URL=

# Debrid: verbose logging (engine + HTTP requests)
DEBRID_VERBOSE=false

# Debrid: retry base delay for HTTP 429 (rate limit)
# Default schedule: 1st retry = 3s, 2nd = 6s, 3rd = 9s
DEBRID_RETRY_DELAY_MS=3000

# Release size limits (GiB)
# Example: MIN_GIB=1 (ignore OST/small files), MAX_GIB=10
MIN_GIB=1
MAX_GIB=10

# Maximum number of releases to keep/print per movie
MAX_TORRENTS=20

# If true/1, only return 1080p or 2160p (4K) releases when at least one exists.
# If none exist, fall back to the non-HD list.
HD_ONLY=true

# If true/1, require the release title to match the Letterboxd movie title (token-based).
# Helps avoid non-English titles.
ENGLISH_TITLE_ONLY=true

# Optional: terms to exclude from release titles (comma-separated)
# Example: EXCLUDE_TERMS=il fantasma,el fantasma,castellano
EXCLUDE_TERMS=

# Size bucket (GiB) used for de-duplication (does not affect MIN/MAX filtering)
DEDUPE_SIZE_BUCKET_GIB=0.1

# If true/1, inspect torrent metadata and only accept releases that have:
# - at least one video (.mkv/.mp4)
# - at least one subtitle (.srt)
INSPECT_METADATA=false

# Metadata inspection timeout (ms)
METADATA_TIMEOUT_MS=120000

# How many metadata inspections to run in parallel
METADATA_CONCURRENCY=5

# Concurrency for Prowlarr searches
CONCURRENCY=3

# Prowlarr request timeout (ms)
# 5 min = 300000
PROWLARR_TIMEOUT_MS=300000

# Cache file (JSON)
CACHE_FILE=cache.json

# If true/1, rewrite the cache entry for a movie even if it already exists.
# (Only affects the current movie; does not touch other cached movies.)
REWRITE_CACHE=false

# Limit how many NEW movies can be added to the cache per run.
# Helps prevent bursts when you add many items to the Letterboxd list at once.
# Set to 0 to disable the limit.
MAX_NEW_MOVIES_PER_RUN=5

# Letterboxd list URL (used by cli.js when no list URL is passed as CLI arg)
LETTERBOXD_LIST_URL=

# If true/1, after cli.js finishes, it runs debrid-cli.js and passes the pending movies array via stdin.
EXECUTE_DEBRID=false

# If true/1, (stub) automatically downloads the file when a torrent becomes downloaded
AUTO_DOWNLOAD=false

# Destination folder for the FINAL movie library location (when AUTO_DOWNLOAD=true)
# Example (Linux): /path/to/Movies
# Example (Windows): C:\\Videos\\Movies
AUTO_DOWNLOAD_DEST_DIR=

# Staging folder used during download/extract. Keep this OUTSIDE the Plex library.
# Defaults to: <project-root>/Downloads
AUTO_DOWNLOAD_STAGING_DIR=

# Path to 7z binary (only needed when extracting .rar archives)
# - Linux/macOS: usually just install p7zip and keep this empty.
# - Windows: install 7-Zip and either add it to PATH or set this to:
#   C:\\Program Files\\7-Zip\\7z.exe
SEVEN_ZIP_PATH=

# Folder naming for movie destination/staging folders:
# If true/1 (default), the folder name is ONLY the movie name (no year, no tmdb id).
# If false/0, it becomes: name-year-tmdb_<tmdbId> (when tmdbId can be resolved), else name-year.
DIR_NAME_MOVIE_ONLY=true

# If true/1 (default), reuse already-downloaded files in the staging folder.
# Useful when a run gets killed mid-download/move.
AUTO_DOWNLOAD_REUSE_STAGING=true

# Plex (optional refresh after download)
PLEX_BASE_URL=http://127.0.0.1:32400
PLEX_TOKEN=

# Library/section id to refresh ("Filmes" is usually 1)
PLEX_SECTION_ID_FILMES=1

# If true/1, call Plex refresh after an auto-download finishes
PLEX_REFRESH_AFTER_DOWNLOAD=false

# Radarr (optional: add movie after download so Bazarr can fetch subtitles)
RADARR_BASE_URL=http://127.0.0.1:7878
RADARR_API_KEY=
RADARR_QUALITY_PROFILE_ID=7
# Example (Linux): /path/to/Movies
# Example (Windows): C:\\Videos\\Movies
RADARR_ROOT_FOLDER_PATH=/path/to/Movies
RADARR_IMPORT_AFTER_DOWNLOAD=false

# Logging
# If true/1, append run events to a daily log file under ./logs
LOGS_ENABLED=false
# How many days of logs to keep (counts today). 1=today only, 2=today+yesterday, ...
LOGS_RETENTION_DAYS=2

# If 1, also print detailed JSON at the end (when supported)
OUTPUT_JSON=0
